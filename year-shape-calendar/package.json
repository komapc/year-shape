    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitest/ui": "^4.1.9",
    "autoprefixer": "^10.5.2",
    "eslint": "^10.7.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
